{
  "name": "claude-browser",
  "version": "0.1.0",
  "description": "Desktop browser with Claude as the search/answer engine — three modes (Web, Image, AI) sharing one address bar.",
  "private": true,
  "main": "out/main/index.js",
  "author": "Pikammmmm",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "package": "electron-vite build && electron-builder --win --x64",
    "rebuild": "electron-rebuild -f -w better-sqlite3,keytar",
    "icon": "node scripts/make-icon.mjs",
    "postinstall": "electron-builder install-app-deps",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.5.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.3.0",
    "keytar": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-window": "^1.8.10",
    "remark-gfm": "^4.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.5",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.1"
  }
}
