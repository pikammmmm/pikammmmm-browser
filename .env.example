# Claude OAuth (sign-in with Claude). Fill these once Anthropic exposes a third-party
# OAuth client ID for desktop apps. Until then, the app falls back to the API-key
# paste flow in Settings.
CLAUDE_OAUTH_CLIENT_ID=
CLAUDE_OAUTH_AUTH_URL=https://claude.ai/oauth/authorize
CLAUDE_OAUTH_TOKEN_URL=https://api.anthropic.com/oauth/token

# Anthropic API base URL (override only if you proxy)
ANTHROPIC_API_URL=https://api.anthropic.com

# Tavily API key — free tier (1,000 queries/month, no card) at https://app.tavily.com/
# (or paste it once in Settings; the .env value is just a convenience for dev.)
TAVILY_API_KEY=

# Default Claude model
CLAUDE_MODEL=claude-opus-4-7
